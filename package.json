		"@simonwep/pickr": "^1.9.1",
		"@sveltejs/adapter-node": "^2",
		"@tinymce/tinymce-svelte": "^3.0.0",
		"chart.js": "4.5.1",
		"currency.js": "^2.0.4",
		"date-fns": "^2.30.0",

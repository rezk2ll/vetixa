		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.0.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^4.0.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^7.0.0",
